# Скопируй этот файл в .env и заполни ТОЛЬКО если используешь AI-генерацию статей.
# Файл .env в git не попадает (см. .gitignore) — ключи остаются у тебя на машине.

# Ключ Claude API для авто-написания статей (scripts/generate-articles.mjs).
# Получить: https://console.anthropic.com/  (это платный сервис — включать по желанию).
ANTHROPIC_API_KEY=

# Сколько статей генерировать за один запуск генератора.
GENERATE_BATCH_SIZE=3
