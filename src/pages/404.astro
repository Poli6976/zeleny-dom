---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Страница не найдена" noindex={true}>
  <div class="container" style="padding-block: 80px; text-align: center;">
    <div style="font-size: 3rem;">🌱</div>
    <h1>Эта страница ещё не проросла</h1>
    <p style="color: var(--text-soft);">
      Страница не существует или была перемещена.
    </p>
    <p style="margin-top: 24px;"><a class="btn" href="/">← На главную</a></p>
  </div>
</BaseLayout>
