---
import { SITE, CATEGORIES } from '../site.config.mjs';
import { categoryUrl } from '../lib/urls.mjs';
---

<header class="site-header">
  <div class="container container-wide bar">
    <a href="/" class="brand">
      <span class="leaf">🌿</span>
      <span>{SITE.name}</span>
    </a>
    <nav class="nav" aria-label="Основное меню">
      {CATEGORIES.map((c) => <a href={categoryUrl(c.slug)}>{c.title}</a>)}
      <a href="/lunnyj-kalendar">Лунный календарь</a>
      <a href="/o-saite">О сайте</a>
    </nav>
  </div>
</header>
