---
import { SITE, CATEGORIES } from '../site.config.mjs';
import { categoryUrl } from '../lib/urls.mjs';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container container-wide cols">
    <div style="flex: 1 1 240px;">
      <h4>{SITE.name}</h4>
      <p style="max-width: 320px;">{SITE.tagline}</p>
    </div>
    <div>
      <h4>Разделы</h4>
      {CATEGORIES.map((c) => (
        <div><a href={categoryUrl(c.slug)}>{c.title}</a></div>
      ))}
      <div><a href="/lunnyj-kalendar">Лунный календарь</a></div>
    </div>
    <div>
      <h4>Сайт</h4>
      <div><a href="/o-saite">О сайте</a></div>
      <div><a href="/partnyorskaya-programma">Партнёрские ссылки</a></div>
      <div><a href="/politika-konfidencialnosti">Политика конфиденциальности</a></div>
      <div><a href="/rss.xml">RSS-лента</a></div>
    </div>
  </div>
  <div class="container container-wide" style="margin-top: 28px; opacity: 0.8;">
    <p>
      © {year} «{SITE.name}». Материалы носят справочный характер. На сайте есть
      партнёрские ссылки: покупая по ним, вы поддерживаете проект без переплаты.
    </p>
  </div>
</footer>
