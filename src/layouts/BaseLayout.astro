---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, MONETIZATION, ANALYTICS } from '../site.config.mjs';
import { absoluteUrl } from '../lib/urls.mjs';

/**
 * @typedef {Object} Props
 * @property {string} title
 * @property {string} [description]
 * @property {string} [image]
 * @property {'website'|'article'} [type]
 * @property {object} [jsonLd] произвольный JSON-LD объект (Article/BreadcrumbList и т.п.)
 * @property {boolean} [noindex]
 */
const {
  title,
  description = SITE.description,
  image,
  type = 'website',
  jsonLd,
  noindex = false,
} = Astro.props;

const pageTitle = title === SITE.name ? title : `${title} · ${SITE.name}`;
const canonical = absoluteUrl(Astro.url.pathname, SITE.url);
const ogImage = image ? absoluteUrl(image, SITE.url) : undefined;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="author" content={SITE.author} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={SITE.locale} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter/OG карточка -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

    <!-- Шрифты стиля Mocha Earth -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600;700;800&display=swap"
    />

    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')}
        />
      )
    }

    <!-- Яндекс РСЯ (загружается только если задан ID блока) -->
    {
      MONETIZATION.yandexRtbBlockId && (
        <script src="https://yandex.ru/ads/system/context.js" async />
      )
    }

    <!-- Яндекс.Метрика (только если задан номер счётчика) -->
    {
      ANALYTICS.yaMetrikaId && (
        <>
          <script is:inline set:html={`(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};m[i].l=1*new Date();for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return;}}k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})(window,document,"script","https://mc.yandex.ru/metrika/tag.js","ym");ym(${ANALYTICS.yaMetrikaId},"init",{clickmap:true,trackLinks:true,accurateTrackBounce:true});`} />
          <noscript><div><img src={`https://mc.yandex.ru/watch/${ANALYTICS.yaMetrikaId}`} style="position:absolute; left:-9999px;" alt="" /></div></noscript>
        </>
      )
    }
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
